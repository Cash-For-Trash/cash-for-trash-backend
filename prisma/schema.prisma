// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  worker
  admin
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum CollectionStatus {
  PENDING
  ACCEPTED
  ON_THE_WAY
  COLLECTED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum RewardStatus {
  PENDING
  APPROVED
  REJECTED
  DELIVERED
}

enum DayOfWeek {
  SATURDAY
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}

model PointsTransaction {
  point_id String @id @default(cuid())

  user_id String
  user    User   @relation(fields: [user_id], references: [user_id])

  points      Int
  reason      String   @db.VarChar(100)
  points_date DateTime @default(now())
  created_at  DateTime @default(now())

  @@index([user_id])
}

model Availability {
  availability_id String @id @default(cuid())

  location    String    @db.VarChar(300)
  day_of_week DayOfWeek
  from_time   DateTime
  to_time     DateTime

  workerAvailabilities WorkerAvailability[]

  @@index([day_of_week])
}

model GarbageType {
  garbage_type_id String @id @default(cuid())

  garbage_type_name  String  @db.VarChar(100)
  garbage_type_image String  @db.VarChar(512)
  price_per_kg       Decimal @db.Decimal(10, 2)

  requestGarbages RequestGarbage[]
}

model RequestGarbage {
  request_garbage_id String @id @default(cuid())

  collection_request_id String
  collectionRequest     CollectionRequest @relation(fields: [collection_request_id], references: [collection_request_id])

  garbage_type_id String
  garbageType     GarbageType @relation(fields: [garbage_type_id], references: [garbage_type_id])

  actual_weight Decimal? @db.Decimal(10, 2)
  earned_points Int?

  @@index([collection_request_id])
  @@index([garbage_type_id])
}

model CollectionRequest {
  collection_request_id String @id @default(cuid())

  user_id String
  user    User   @relation(fields: [user_id], references: [user_id])
  address_id String
  address Address @relation(fields: [address_id], references: [address_id])

  request_date   DateTime         @default(now())
  quantity       Decimal          @db.Decimal(10, 2)
  collection_img String?          @db.VarChar(512)
  status         CollectionStatus

  requestGarbages RequestGarbage[]
  payments        Payment?

  workerRequests WorkerCollectionRequest[]

  @@index([user_id, request_date])
  @@index([status, request_date])
}

model Payment {
  payment_id String @id @default(cuid())

  collection_request_id String @unique

  collectionRequest CollectionRequest @relation(fields: [collection_request_id], references: [collection_request_id])

  payment_method String        @db.VarChar(60)
  payment_status PaymentStatus

  payment_date   DateTime @default(now())
  payment_amount Decimal  @db.Decimal(10, 2)

  orders Order[]
}

model Order {
  order_id String @id @default(cuid())

  payment_id String
  payment    Payment @relation(fields: [payment_id], references: [payment_id])

  user_id String
  user    User   @relation(fields: [user_id], references: [user_id])

  total_price Decimal @db.Decimal(10, 2)
  final_price Decimal @db.Decimal(10, 2)

  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt
  status     OrderStatus

  items OrderItem[]

  @@index([user_id, created_at])
  @@index([status])
}

model OrderItem {
  orderItem_id String @id @default(cuid())

  order_id String
  order    Order  @relation(fields: [order_id], references: [order_id])

  product_id String
  product    Product @relation(fields: [product_id], references: [product_id])

  unit_price Decimal @db.Decimal(10, 2)
  quantity   Int

  @@index([product_id])
}

model Product {
  product_id     String      @id @default(cuid())
  name           String      @db.VarChar(100)
  description    String      @db.VarChar(300)
  stock_quantity Int
  image          String?     @db.VarChar(512)
  price          Decimal     @db.Decimal(10, 2)
  orderItems     OrderItem[]
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  @@index([name])
}

model WorkerCollectionRequest {
  user_id               String
  collection_request_id String

  worker            Worker            @relation(fields: [user_id], references: [user_id])
  collectionRequest CollectionRequest @relation(fields: [collection_request_id], references: [collection_request_id])

  @@id([user_id, collection_request_id])
  @@index([collection_request_id])
}

model WorkerAvailability {
  availability_id String
  user_id         String

  availability Availability @relation(fields: [availability_id], references: [availability_id])
  worker       Worker       @relation(fields: [user_id], references: [user_id])

  @@id([availability_id, user_id])
  @@index([user_id])
}

model Notification {
  notification_id String @id @default(cuid())

  user_id String
  user    User   @relation(fields: [user_id], references: [user_id])

  message String @db.VarChar(500)
  title   String @db.VarChar(100)

  is_read Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id, is_read])
  @@index([created_at])
}

model User {
  user_id String @id @default(cuid())

  first_name String @db.VarChar(30)
  last_name  String @db.VarChar(30)

  email    String @unique @db.VarChar(255)
  password String @db.VarChar(255)

  mobile String? @db.VarChar(20)

  image String? @db.VarChar(512)

  role Role

  otp            String?   @db.VarChar(6)
  otp_expires_at DateTime?

  reset_password_otp            String?   @db.VarChar(6)
  reset_password_otp_expires_at DateTime?

  is_verified Boolean @default(false)
  is_active   Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  customer Customer?
  worker   Worker?
  admin    Admin?

  addresses Address[]

  notifications     Notification[]
  pointTransactions PointsTransaction[]

  collectionRequests CollectionRequest[]
  orders             Order[]

  @@index([role, is_active])
}

model Address {
  address_id String @id @default(cuid())

  building_num    Int
  floor           String?
  location        String  @db.VarChar(300)
  latitude        Decimal @db.Decimal(10, 7)
  longitude       Decimal @db.Decimal(10, 7)
  additional_note String? @db.VarChar(500)

  user_id String
  user    User   @relation(fields: [user_id], references: [user_id])
    collectionRequests CollectionRequest[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
}

model Customer {
  user_id String @id

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  points Decimal @default(0) @db.Decimal(10, 2)

  rewardRedemptions RewardRedemption[]
}

model Worker {
  user_id String @id

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  national_id String @unique @db.VarChar(14)

  is_approved Boolean   @default(false)
  approved_at DateTime?

  workerRequests     WorkerCollectionRequest[]
  workerAvailability WorkerAvailability[]

  created_at DateTime @default(now())

  updated_at DateTime @updatedAt
}

model Admin {
  user_id String @id

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
}

model Reward {
  reward_id String @id @default(cuid())

  name String @db.VarChar(100)

  required_points Decimal @db.Decimal(10, 2)

  image String? @db.VarChar(512)

  rewardRedemptions RewardRedemption[]
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
}

model RewardRedemption {
  redemption_id String @id @default(cuid())

  user_id  String
  customer Customer @relation(fields: [user_id], references: [user_id])

  reward_id String
  reward    Reward @relation(fields: [reward_id], references: [reward_id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  points_spent Decimal @db.Decimal(10, 2)

  status RewardStatus

  @@index([user_id, status])
}
