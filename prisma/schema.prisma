// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


model PointsTransaction {
  point_id    String   @id @default(cuid()) 

  user_id     String
  user        User     @relation(fields: [user_id], references: [user_id])

  points      Int
  status      String   @db.VarChar(50)
  points_date DateTime @default(now())
}

model Availability {
  availability_id String   @id @default(cuid())

  location        String   @db.VarChar(300)
  day_of_week     String   @db.VarChar(15)
  from_time       DateTime
  to_time         DateTime

  workerAvailabilities WorkerAvailability[]
}

model GarbageType {
  garbage_type_id    String   @id @default(cuid())

  garbage_type_name  String   @db.VarChar(100)
  garbage_type_image String   @db.VarChar(512)
  price_per_kg       Decimal  @db.Decimal(10,2)

  requestGarbages    RequestGarbage[]
}

model RequestGarbage {
  request_garbage_id     String   @id @default(cuid())

  collection_request_id  String
  collectionRequest      CollectionRequest @relation(fields: [collection_request_id], references: [collection_request_id])

  garbage_type_id        String
  garbageType            GarbageType @relation(fields: [garbage_type_id], references: [garbage_type_id])

  actual_weight          Decimal @db.Decimal(10,2)
  earned_points          Int
}

model CollectionRequest {
  collection_request_id String   @id @default(cuid())

  user_id              String
  user                 User @relation(fields: [user_id], references: [user_id])

  request_date         DateTime @default(now())
  quantity             Decimal @db.Decimal(10,2)
  collection_img       String @db.VarChar(512)
  status               String @db.VarChar(40)

  requestGarbages      RequestGarbage[]
  payments             Payment[]
  workerRequests       Worker_collection_request[]
}

model Payment {
  payment_id            String @id @default(cuid())

  collection_request_id String
  collectionRequest     CollectionRequest @relation(fields: [collection_request_id], references: [collection_request_id])

  payment_method        String @db.VarChar(60)
  payment_status        String @db.VarChar(40)

  payment_date          DateTime @default(now())
  payment_amount        Decimal @db.Decimal(10,2)

  orders                Order[]
}

model Order {
  order_id      String @id @default(cuid())

  payment_id    String
  payment       Payment @relation(fields: [payment_id], references: [payment_id])

  user_id       String
  user          User @relation(fields: [user_id], references: [user_id])

  total_price   Decimal @db.Decimal(10,2)
  final_price   Decimal @db.Decimal(10,2)

  order_date    DateTime @default(now())
  status        String @db.VarChar(30)

  items         OrderItem[]
}

model OrderItem {
  orderItem_id  String @id @default(cuid())

  order_id      String
  order         Order @relation(fields: [order_id], references: [order_id])

  product_id    String
  product       Product @relation(fields: [product_id], references: [product_id])

  unit_price    Decimal @db.Decimal(10,2)
  quantity      Int
}

model Product {
  product_id      String @id @default(cuid())

  name            String @db.VarChar(100)
  description     String @db.VarChar(300)
  stock_quantity  Int

  orderItems      OrderItem[]
}

model Worker_collection_request {
  user_id                String
  collection_request_id  String

  user                   User @relation(fields: [user_id], references: [user_id])
  collectionRequest      CollectionRequest @relation(fields: [collection_request_id], references: [collection_request_id])

  @@id([user_id, collection_request_id])
}

model WorkerAvailability {
  workerAvailability_id String @id @default(cuid())

  availability_id       String
  availability          Availability @relation(fields: [availability_id], references: [availability_id])

  user_id               String
  user                  User @relation(fields: [user_id], references: [user_id])
}

model Notification {
  notification_id String @id @default(cuid())

  user_id         String
  user            User @relation(fields: [user_id], references: [user_id])

  message         String @db.VarChar(500)
  name            String @db.VarChar(100)

  is_read         Boolean @default(false)

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

